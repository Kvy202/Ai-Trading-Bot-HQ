# =============================================================================
# .env for AI trading bot
# =============================================================================
# This file is loaded by python-dotenv on startup. Lines starting with `#`
# are comments. Inline comments after values can confuse some parsers, so
# we keep comments on their own lines.
#
# Boolean handling note:
#   - trade_multi_bitget.py reads booleans as bool(int(env)) -> use 0 or 1.
#   - live_executor.py / live_writer.py / async_scanner.py / etc. accept
#     0/1/true/false/yes/no. Stick with 0/1 throughout for consistency.
#
# CONFIG SPLIT: two-file config model
# ------------------------------------
#   .env              → SECRETS + venue identity (API keys, tokens, exchange ID)
#                       Also used for emergency overrides of run.json values.
#   config/run.json   → RUNTIME KNOBS (thresholds, limits, tunable params)
#
# Priority chain (highest → lowest):
#   shell env > .env (override=True) > config/run.json
#
# Migration: params duplicated in both places always use the .env value.
# To hand control to run.json for a param: delete it from .env.
#
# Params already in config/run.json (can be removed from .env once confirmed):
#   Signal:    PRED_THRESHOLD, DL_P_LONG, DL_P_LONG_MODE, DL_MIN_AGREE, DL_ALLOW_ONLY
#   Risk:      RISK_PER_TRADE, MAX_NOTIONAL_USDT, PER_SYMBOL_NOTIONAL_USDT,
#              MAX_PORTFOLIO_EXPOSURE_USDT, MAX_CONCURRENT, MAX_DD,
#              MAX_HOLD_BARS, COOLDOWN_BARS, STOP_ATR_MULT, TP_R_MULT
#   Executor:  EXEC_TP_PCT, EXEC_SL_PCT, EXEC_RV_MAX, EXEC_COOLDOWN_SEC
#   Universe:  DL_SYMBOLS, DL_TIMEFRAME, DL_SEQ_LEN, DL_HORIZON_K,
#              DL_MAX_LOOKBACK_PAD, DL_BATCH
#   Models:    DL_MODEL_KIND, DL_TEMP_LSTM, DL_TEMP_TCN, DL_TEMP_TX
#   Features:  FEATURE_* params, IMB_ABS_MIN, RV_STOP_MULT, VOLZ_MIN, RSI_MIN/MAX
#   Exchange:  LEVERAGE, POSITION_MODE, MARGIN_MODE, CCXT_*
# =============================================================================


# ===== Venue / mode =====
EXCHANGE_ID=bitget
LIVE_MODE=0
DERIVS=1
BITGET_SANDBOX=0
EXEC_PAPER=1


# ===== Hyperliquid (Phase 1 — official SDK execution) =====
# Select the execution venue. 'hyperliquid' uses the official Hyperliquid SDK;
# 'bitget' uses the legacy ccxt path. If unset, falls back to EXCHANGE_ID above.
EXCHANGE=hyperliquid
# development | testnet | production  (production is REQUIRED for mainnet real money)
ENVIRONMENT=development

# ---- Safety mode (defaults below are SAFE — paper, no real money) ----
# Real-money master switch. Must be true (AND all confirmations below) to trade live.
LIVE_TRADING=false
# Simulate fills locally. Keep true for paper trading.
PAPER_TRADING=true
# Use Hyperliquid testnet (no real money). Keep true for demonstrations.
HL_TESTNET=true
# Typed confirmation gate for MAINNET real money. Leave BLANK for paper/testnet.
# To enable real money this must equal EXACTLY: I_UNDERSTAND_LIVE_TRADING
CONFIRM_LIVE_TRADING=

# ---- Hyperliquid credentials (PLACEHOLDERS — never commit real values) ----
# Main wallet PUBLIC address (0x + 40 hex). Used as account_address; this is the
# account whose funds/positions are traded. A public address, not a secret.
HL_ACCOUNT_ADDRESS=0xYourMainWalletPublicAddressHere
# API/AGENT wallet private key (0x + 64 hex). Used ONLY to sign orders; an
# approved agent wallet CANNOT withdraw. Create/approve it in the Hyperliquid UI
# (API section) first. NEVER put your main wallet's private key here.
HL_AGENT_PRIVATE_KEY=0xYourAgentWalletPrivateKeyHere
# Optional: market-order slippage tolerance (fraction). Default 0.05 = 5%.
HL_SLIPPAGE=0.05


# Bitget perps / margin
LEVERAGE=5
# POSITION_MODE: oneway | hedge
POSITION_MODE=oneway
# MARGIN_MODE: cross | isolated
MARGIN_MODE=cross


# ===== Universe / scan =====
# SCAN_TOPN=0 means: skip volume-based scan, use SYMBOL_WHITELIST only.
SCAN_TOPN=0
SCAN_MIN_NOTIONAL=100000
SANITIZE_UNIVERSE=0
SANITIZE_WORKERS=8
# IMPORTANT: SYMBOL_WHITELIST format must match what the writer emits in
# logs/live_signals.csv, which is the compact form (BTCUSDT, not BTC/USDT:USDT).
# The executor's Broker class normalizes these to ccxt unified form
# (BTC/USDT:USDT) at order-placement time, so live trading still works.
# If you put 'BTC/USDT:USDT' here, the executor logs "SKIP ... reason=not_whitelisted"
# for every signal because the strings don't match.
SYMBOL_WHITELIST=BTCUSDT,ETHUSDT,DOGEUSDT,XRPUSDT,1000BONKUSDT,1000PEPEUSDT


# ===== Strategy / risk (baseline) =====
TIMEFRAME=5m
LOOKBACK_CANDLES=2000
RISK_PER_TRADE=0.0025
STOP_ATR_MULT=2.5
TP_R_MULT=3.0
# Time-stop knobs:
#   - MAX_HOLD_BARS is the reliable one (read by trade_multi_bitget after dotenv).
#   - TIME_STOP_BARS is read inside risk_engine.py at import time, BEFORE
#     load_dotenv() runs in trade_multi_bitget. So it defaults to 0 unless
#     you set it as an OS-level env var. Don't rely on it from .env.
# 48 bars * 5m = 4-hour max hold.
MAX_HOLD_BARS=48
TIME_STOP_BARS=0
# Loosened from 0.55 to 0.45 for INITIAL paper testing - you want to see
# trades happening so you can verify the pipeline end-to-end. Once trades
# are flowing, raise back to 0.55 for normal paper running. Same for DL_P_LONG.
PRED_THRESHOLD=0.55
LONG_ONLY=0
SHORT_ONLY=0
FEES_BPS=6
START_EQUITY=50.0
SEED=42
MAX_DD=0.05
COOLDOWN_BARS=3
MAX_CONCURRENT=2


# ===== Hard caps for tiny accounts =====
# At $50 equity, $15 notional with 5x leverage = $3 of margin per trade.
# MAX_PORTFOLIO_EXPOSURE_USDT=30 caps total open exposure to 2 concurrent trades.
MAX_NOTIONAL_USDT=15
MAX_MARGIN_FRACTION=0.25


# ===== Router / slippage guard =====
# IMPORTANT: code reads ENABLE_ROUTER, NOT ROUTER_ENABLED.
# (The variable inside router.py is called ROUTER_ENABLED but it reads
#  os.getenv("ENABLE_ROUTER", "0") - the env var name is ENABLE_ROUTER.)
ENABLE_ROUTER=1
ROUTER_DEFAULT_TAKER_BPS=10
SLIPPAGE_MAX_BPS=40


# ===== Live executor (paper-mode TP/SL knobs) =====
# These ONLY affect tools/live_executor.py. They have no effect on
# trade_multi_bitget.py.
#
# IMPORTANT NAME WARNING: ChatGPT/other tools sometimes suggest names like
# EXEC_THRESHOLD, EXEC_EXIT_THRESHOLD, MAX_HOLD_MINUTES, TAKE_PROFIT_PCT,
# STOP_LOSS_PCT. None of those exist in the code. The names below are the
# real ones. Don't rename.
#
# - EXEC_TP_PCT: take-profit % from entry price. 0.003 = +0.3%.
# - EXEC_SL_PCT: stop-loss % from entry price.  0.005 = -0.5%.
#   GEOMETRY MUST MATCH THE TRAINED LABEL BARRIER. The 5m models are trained
#   on ~0.3%/36-bar triple-barrier labels: they predict SMALL moves. A wide TP
#   (e.g. 1.5%) is never reached on 5m — flips exit first and only the SL ever
#   fires, so the SL becomes the sole large-loss path (observed live: 0 TP hits
#   in 78 trades, 100% of net loss from EXIT_SL at 1%). Keep TP/SL within a
#   small multiple of the label barrier (e.g. 0.005/0.005 for 5m).
# - EXEC_RV_MAX: skips entries when rv_mean > this value. Your writer is
#   currently reporting rv_mean values around 35-40 (not 0.0-0.05), which
#   means the default DL_MAX_RV=0.02 would block every entry. 100 disables
#   the guard for paper testing. The rv-scale mismatch is a separate bug
#   to investigate later; for now we just turn the guard off.
EXEC_TP_PCT=0.01
EXEC_SL_PCT=0.02
EXEC_RV_MAX=100
EXEC_COOLDOWN_SEC=120

# - EXEC_FEE_BPS: taker fee per side, in basis points (1 bp = 0.01%).
#   5 = 0.05%/side ~= 0.10% round-trip. Charged on entry AND exit notional so
#   paper P&L reflects real exchange fees instead of optimistic mid-price fills.
# - EXEC_SLIPPAGE_BPS: adverse slippage per side, in basis points. 2 = 0.02%/side.
#   Worsens every fill (buys fill higher, sells lower). TP/SL still TRIGGER on the
#   observed mid; only the fill price is made adverse.
#   Set both to 0 to reproduce the old cost-free (optimistic) paper behaviour.
EXEC_FEE_BPS=5
EXEC_SLIPPAGE_BPS=2

# ===== Bitget / ccxt hardening =====
# CCXT_TIMEOUT_MS lowered from 120000ms (2 min) to 30000ms (30 s).
# Combined with CCXT_RETRIES=3, worst case blocking is ~90s instead of 16min.
CCXT_TIMEOUT_MS=30000
CCXT_RETRIES=3
CHECK_OPEN_ORDERS=0
CCXT_DEBUG=0


# ===== Day 3 - Risk Engine =====
RISK_ATR_MULT=2.5
RISK_RV_MULT=2.0
RISK_MIN_STOP_FRAC=0.002
MAX_PORTFOLIO_EXPOSURE_USDT=31
PER_SYMBOL_NOTIONAL_USDT=15
SPREAD_PAUSE_BPS=15
SPREAD_WIDEN_MULT=2.5
SPREAD_LOOKBACK=20
# Note: TIME_STOP_BARS lives up in the Strategy section. It's set to 0 there
# because risk_engine reads it at import time (before .env is loaded by
# trade_multi_bitget). MAX_HOLD_BARS=48 is the working knob.


# ===== Day 1 - Feature pipeline =====
FEATURE_ENABLE=1
FEATURE_TIMEFRAME=1m
FEATURE_KLINE_LIMIT=1200
FEATURE_EMA_WINDOWS=20,50,100
FEATURE_RSI=14
FEATURE_RV=30
FEATURE_VOLZ=60
IMB_ABS_MIN=0.00
RV_STOP_MULT=2.0
VOLZ_MIN=-2.0
RSI_MIN=10
RSI_MAX=90
SPREAD_GUARD_BPS=20


# ===== Day 4 - DL inference =====
# USE_DL_SIGNALS=0 for INITIAL paper testing. This forces the bot to use the
# classical (Day 3) signal path, which is simpler and easier to validate.
# Once trades are flowing and you've verified the pipeline, set USE_DL_SIGNALS=1
# to enable the DL ensemble.
USE_DL_SIGNALS=1
QUIET_LABELS=1
QUIET_DATA=1
# DL_MODEL_KIND: tcn | tx
DL_MODEL_KIND=tcn
# Explicit DL writer inputs. Keep these separate from the broader
# SYMBOL_WHITELIST/TIMEFRAME until the six-symbol 5m feature path is fixed.
DL_SYMBOLS=BTCUSDT,ETHUSDT
DL_TIMEFRAME=1m
DL_SEQ_LEN=64
DL_HORIZON_K=12
DL_BATCH=256
# Centered-signal threshold. The writer now emits p_meta = p_long - 0.5 so the
# signal is signed (>0 = bullish/LONG, <0 = bearish/SHORT). DL_P_LONG is the
# absolute distance from 0 required to fire:
#   LONG  when p_long >= 0.5 + DL_P_LONG  (e.g. >= 0.58 with thr=0.08)
#   SHORT when p_long <= 0.5 - DL_P_LONG  (e.g. <= 0.42 with thr=0.08)
# 0.08 is a tight but honest gate given current model outputs (avg ~0.23 raw).
DL_P_LONG=0.08
DL_MAX_RV=0.02
# DL_ADD_SYMBOL_ID controls the per-symbol id channel appended to the 26 base
# FEATURE_COLS. It must match the deployed scaler width or the writer + parity
# check fail loud:
#   1 = append symbol_id -> 27 features  (CURRENT committed artifacts: 26 base + symbol_id)
#   0 = no symbol_id     -> 26 features  (only for 26-wide artifacts)
# Leave unset to auto-derive from the scaler's n_features_in_ (recommended).
DL_ADD_SYMBOL_ID=1
DL_SCALER_PATH=model_artifacts/scaler_latest.joblib
# Fixed from the malformed markdown link that was here before.
DL_MODEL_PATH=model_artifacts/dl_tcn_latest.pt
# Per-model temperature scaling. T > 1 compresses overconfident probabilities
# toward 0.5 in logit space (p=0.93 with T=2 → ~0.78; p=0.05 with T=2 → ~0.18).
# Use DL_TEMP_LSTM=2.0 to fix LSTM overconfidence; leave others at 1.0.
DL_TEMP_LSTM=1.0
DL_TEMP_TCN=1.0
DL_TEMP_TX=1.0
# Minimum number of models that must be bullish (p > 0.5) to allow a long signal.
# Only enforced when at least this many models are active. Set to 1 to disable.
# When fewer than DL_MIN_AGREE models agree on a side, the blend is suppressed
# to NEUTRAL (p=0.5 -> centered 0.0 -> FLAT, allow=0). Models given weight 0 in
# DL_MODEL_WEIGHTS still predict and are logged, but do NOT vote in this gate —
# use weight 0 to silence a dead/flat model (e.g. DL_MODEL_WEIGHTS=tcn:0,...).
DL_MIN_AGREE=2
# Blend weights per model. Weight 0 removes a model from BOTH the blend and the
# agree-gate vote while keeping its predictions in the diagnostic logs.
# Unset -> AUC-derived weights from each model's metadata.
# DL_MODEL_WEIGHTS=adv:0.78,lstm:0.75,tx:0.75,tcn:0


# ===== Backtest knobs (only used by backtest.py) =====
BT_FEE_BPS=6
BT_IMPACT_COEFF=3
BT_LATENCY_BARS=1
BT_INIT_EQUITY=1000
BT_RISK_PER_TRADE=0.003
BT_TIME_STOP_BARS=0
BT_MAX_NOTIONAL_USDT=0
BT_MAX_MARGIN_FRACTION=1.0
BT_MAX_PORTFOLIO_EXPOSURE_USDT=0
BT_SPREAD_PAUSE_BPS=15
BT_SPREAD_WIDEN_MULT=2.5
BT_SPREAD_LOOKBACK=20
BT_SLIPPAGE_MAX_BPS=60
BT_GAP_MAX_MINUTES=15
BT_DAILY_MAX_DD=0.1


# ===== Paths / logging =====
# IMPORTANT: trade_multi_bitget.py crashes if MODEL_PATH file is missing.
# Verify this exists before starting the bot.
MODEL_PATH=models/model.pkl
LOG_PATH=logs/trades.csv
RUNTIME_LOG=logs/runtime.log
# Renamed from heartbeat.json to avoid conflict with live_executor.py
# (live_executor.py also writes logs/heartbeat.json - they would clobber each other).
HEARTBEAT_PATH=logs/trader_heartbeat.json
QUIET_MODE=1
SPINNER=0
COLOR=1
RUNTIME_THROTTLE_MS=1200
FOREGROUND_LOG=1
FG_SYNC_THROTTLE_S=60


# ===== Bitget API (paste real values when going live) =====
# Empty values are fine for LIVE_MODE=0 (paper trading).
# Required when LIVE_MODE=1 and EXEC_PAPER=0.
API_KEY=<YOUR_API_KEY_HERE>
API_SECRET=<YOUR_API_SECRET_HERE>
API_PASSWORD=<YOUR_API_PASSWORD_HERE>


# ===== Telegram =====
TELEGRAM_ENABLED=1
# TELEGRAM_CONTROLLER_TOKEN: token for the Controller Bot (issues commands via Supervisor API).
#   Create a separate bot via BotFather. Falls back to TELEGRAM_BOT_TOKEN if not set.
TELEGRAM_CONTROLLER_TOKEN=<YOUR_TELEGRAM_CONTROLLER_TOKEN_HERE>
# TELEGRAM_NOTIFIER_TOKEN: token for the Notifier Bot (read-only health alerts).
#   Create a separate bot via BotFather. Falls back to TELEGRAM_BOT_TOKEN if not set.
TELEGRAM_NOTIFIER_TOKEN=<YOUR_TELEGRAM_NOTIFIER_TOKEN_HERE>
# Legacy single-bot token (still works; overridden by the per-role tokens above).
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN_HERE>
TELEGRAM_CHAT_ID=<YOUR_TELEGRAM_CHAT_ID_HERE>
TELEGRAM_POLL=1


# ===== Cross-venue keys (optional) =====
# Set to {} when not using authenticated cross-venue access.
# When you DO use it, the value MUST be valid JSON on a single line, e.g.:
#   EX_KEYS_JSON={"binance":{"apiKey":"abc","secret":"def"}}
# A malformed value here is now logged loudly by the rewritten router.py
# (was silent before).
EX_KEYS_JSON=<YOUR_EX_KEYS_JSON_HERE>


# ===== Supervisor API (Trady integration) =====
SUPERVISOR_JWT_SECRET=<YOUR_SUPERVISOR_JWT_SECRET_HERE>
SUPERVISOR_HMAC_SECRET=<YOUR_SUPERVISOR_HMAC_SECRET_HERE>


# ===== DEX (off by default) =====
ANALYZE_DEX=0
# To enable DEX (example for 0x on Ethereum), set:
# ANALYZE_DEX=1
# DEX_AGG_URL=https://api.0x.org/swap/v1/price
# DEX_CHAIN_ID=1
# DEX_TOKEN_MAP={"BTC":"WBTC","ETH":"WETH","USDT":"USDT","PEPE":"PEPE"}
# DEX_ADDR_MAP={"WBTC":"0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599","WETH":"0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2","USDT":"0xdAC17F958D2ee523a2206206994597C13D831ec7","PEPE":"0x6982508145454Ce325dDbE47a25d4ec3d2311933"}
# DEX_DECIMALS={"WBTC":8,"WETH":18,"USDT":6,"PEPE":18}
# DEX_SLIPPAGE_BPS=30
# DEX_GAS_USD=0.50
# DEX_API_KEY=YOUR_KEY
DL_BIAS_LSTM=0.0405
DL_BIAS_TCN=0.0556
DL_BIAS_TX=0.1046
