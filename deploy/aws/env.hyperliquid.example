# =============================================================================
# env.hyperliquid.example — SAFE starter .env for a NEW AWS EC2 instance.
# Copy to the instance as ~/bot/.env, then `chmod 600 ~/bot/.env`.
# Contains PLACEHOLDERS ONLY. Never commit a filled-in copy.
#
# Defaults below = Hyperliquid TESTNET + PAPER trading (no real money).
# See the repo's .env.example for the full set of runtime knobs.
# =============================================================================

# ---- Venue ----
EXCHANGE=hyperliquid
ENVIRONMENT=testnet

# ---- Safety mode (SAFE defaults) ----
LIVE_TRADING=false
PAPER_TRADING=true
HL_TESTNET=true
# Leave blank for paper/testnet. For MAINNET real money it must equal exactly:
#   I_UNDERSTAND_LIVE_TRADING
CONFIRM_LIVE_TRADING=

# ---- Hyperliquid credentials (PLACEHOLDERS — replace on the instance only) ----
# Main wallet PUBLIC address (account_address). Public, not a secret.
HL_ACCOUNT_ADDRESS=0xYourMainWalletPublicAddressHere
# API/AGENT wallet private key (signs only; cannot withdraw). Approve the agent
# wallet in the Hyperliquid UI first. NEVER your main wallet's private key.
HL_AGENT_PRIVATE_KEY=0xYourAgentWalletPrivateKeyHere
HL_SLIPPAGE=0.05

# ---- Strategy / universe (match your trained models) ----
SYMBOL_WHITELIST=BTCUSDT,ETHUSDT
LEVERAGE=5

# ---- Sizing / risk (start tiny on testnet) ----
PER_SYMBOL_NOTIONAL_USDT=15
MAX_PORTFOLIO_EXPOSURE_USDT=31
MAX_CONCURRENT=2
# Hyperliquid minimum order value is ~$10 — keep EXEC_MIN_NOTIONAL >= 10.
EXEC_MIN_NOTIONAL=10
EXEC_TP_PCT=0.01
EXEC_SL_PCT=0.02

# ---- V2 risk controls (kill switch always armed) ----
V2_RISK_DISABLED=0
V2_PAUSE_FILE=run/V2_PAUSE
